WITH condition_metrics AS (
    SELECT 
        Medical_Condition,
        Admission_Type,
        COUNT(*) AS Admission_Count,
        COUNT(DISTINCT Name) AS Unique_Patient_Count,
        ROUND(SUM(Billing_Amount), 2) AS Total_Billed,
        ROUND(AVG(Billing_Amount), 2) AS Avg_Billing_Amount,
        ROUND(MIN(Billing_Amount), 2) AS Min_Billing,
        ROUND(MAX(Billing_Amount), 2) AS Max_Billing,
        ROUND(STDEV(Billing_Amount), 2) AS Billing_Std_Dev,
        ROUND(AVG(CAST(DATEDIFF(DAY, Date_of_Admission, Discharge_Date) AS FLOAT)), 2) AS Avg_Length_of_Stay,
        SUM(CASE WHEN Test_Results = 'Normal' THEN 1 ELSE 0 END) AS Normal_Outcomes,
        SUM(CASE WHEN Test_Results = 'Abnormal' THEN 1 ELSE 0 END) AS Abnormal_Outcomes,
        COUNT(DISTINCT Doctor) AS Unique_Doctors_Involved
    FROM dbo.anv
    GROUP BY Medical_Condition, Admission_Type
)

SELECT 
    Medical_Condition,
    Admission_Type,
    Admission_Count,
    Unique_Patient_Count,
    Total_Billed,
    Avg_Billing_Amount,
    Avg_Length_of_Stay,
    ROUND(Avg_Billing_Amount / NULLIF(Avg_Length_of_Stay, 0), 2) AS Revenue_per_Day_of_Care,
    ROUND(100.0 * Normal_Outcomes / NULLIF((Normal_Outcomes + Abnormal_Outcomes), 0), 2) AS Treatment_Success_Rate_Pct,
    Unique_Doctors_Involved,
    ROUND(Avg_Billing_Amount / NULLIF(Unique_Doctors_Involved, 0), 2) AS Avg_Revenue_per_Doctor,
    CASE
        WHEN Avg_Billing_Amount > 35000 THEN 'PREMIUM'
        WHEN Avg_Billing_Amount > 25000 THEN 'HIGH'
        WHEN Avg_Billing_Amount > 15000 THEN 'STANDARD'
        ELSE 'BUDGET'
    END AS Price_Tier,
    RANK() OVER (ORDER BY Total_Billed DESC) AS Overall_Revenue_Rank
FROM condition_metrics
ORDER BY Total_Billed DESC;
