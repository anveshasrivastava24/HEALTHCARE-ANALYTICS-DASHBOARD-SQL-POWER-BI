-- 1. AGE GROUP CATEGORISATION
-- Count patients in age ranges: 0–18 (Child), 19–35 (Young Adult), 36–60 (Adult), 61+ (Senior)
SELECT
    CASE
        WHEN Age BETWEEN 0 AND 18 THEN 'Child (0-18)'
        WHEN Age BETWEEN 19 AND 35 THEN 'Young Adult (19-35)'
        WHEN Age BETWEEN 36 AND 60 THEN 'Adult (36-60)'
        ELSE 'Senior (61+)'
    END AS AgeGroup,

    COUNT(*) AS PatientCount,
    ROUND(
        COUNT(*) * 100.0 /
        (SELECT COUNT(*) FROM [FINAL CLEANED SHEET]),
        2
    ) AS PercentageOfTotal
FROM [FINAL CLEANED SHEET]
GROUP BY
    CASE
        WHEN Age BETWEEN 0 AND 18 THEN 'Child (0-18)'
        WHEN Age BETWEEN 19 AND 35 THEN 'Young Adult (19-35)'
        WHEN Age BETWEEN 36 AND 60 THEN 'Adult (36-60)'
        ELSE 'Senior (61+)'
    END
ORDER BY
    CASE
        WHEN MIN(Age) BETWEEN 0 AND 18 THEN 1
        WHEN MIN(Age) BETWEEN 19 AND 35 THEN 2
        WHEN MIN(Age) BETWEEN 36 AND 60 THEN 3
        ELSE 4
    END;



-- 2. GENDER CLASSIFICATION OVERALL
SELECT
    Gender,
    COUNT(*) AS PatientCount,
    ROUND(COUNT(*) * 100.0 / (SELECT COUNT(*) FROM [FINAL CLEANED SHEET]), 2) AS PercentageOverall
FROM [FINAL CLEANED SHEET]
GROUP BY Gender;



-- 3. GENDER CLASSIFICATION BY AGE GROUPS
SELECT
    CASE
        WHEN Age BETWEEN 0 AND 18 THEN 'Child (0-18)'
        WHEN Age BETWEEN 19 AND 35 THEN 'Young Adult (19-35)'
        WHEN Age BETWEEN 36 AND 60 THEN 'Adult (36-60)'
        ELSE 'Senior (61+)'
    END AS AgeGroup,
    Gender,
    COUNT(*) AS PatientCount,
    ROUND(COUNT(*) * 100.0 / (SELECT COUNT(*) FROM [FINAL CLEANED SHEET]), 2) AS PercentageOfTotal
FROM [FINAL CLEANED SHEET]
GROUP BY
    CASE
        WHEN Age BETWEEN 0 AND 18 THEN 'Child (0-18)'
        WHEN Age BETWEEN 19 AND 35 THEN 'Young Adult (19-35)'
        WHEN Age BETWEEN 36 AND 60 THEN 'Adult (36-60)'
        ELSE 'Senior (61+)'
    END,
    Gender
ORDER BY
    CASE
        WHEN MIN(Age) BETWEEN 0 AND 18 THEN 1
        WHEN MIN(Age) BETWEEN 19 AND 35 THEN 2
        WHEN MIN(Age) BETWEEN 36 AND 60 THEN 3
        ELSE 4
    END,
    Gender;



-- 4. BLOOD TYPE CATEGORISATION
SELECT
    [Blood_Type],
    COUNT(*) AS PatientCount,
    ROUND(COUNT(*) * 100.0 / (SELECT COUNT(*) FROM [FINAL CLEANED SHEET]), 2) AS PercentageOfTotal
FROM [FINAL CLEANED SHEET]
GROUP BY [Blood_Type]
