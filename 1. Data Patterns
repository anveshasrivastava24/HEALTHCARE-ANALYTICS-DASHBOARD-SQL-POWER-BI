-- 5. MEDICAL CONDITION CATEGORISATION
SELECT
    [Medical_Condition],
    COUNT(*) AS PatientCount,
    ROUND(COUNT(*) * 100.0 / (SELECT COUNT(*) FROM [FINAL CLEANED SHEET]), 2) AS PercentageOfTotal
FROM [FINAL CLEANED SHEET]
